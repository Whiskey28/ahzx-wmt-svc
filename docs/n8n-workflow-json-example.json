      "id": "split-batches",
      "name": "分批处理",
      "type": "n8n-nodes-base.splitInBatches",
      "typeVersion": 3,
      "position": [650, 300]
    },
    {
      "parameters": {
        "jsCode": "// 数据过滤和质量评估\nconst items = $input.all();\n\nconst filteredItems = items\n  .filter(item => {\n    const data = item.json;\n    // 过滤条件：点赞数、评论数、是否已处理\n    return (data.likeCount || 0) > 100 && \n           (data.commentCount || 0) > 10 &&\n           !data.processed;\n  })\n  .map(item => {\n    const data = item.json;\n    // 计算质量分数\n    const qualityScore = ((data.likeCount || 0) * 0.4 + \n                         (data.commentCount || 0) * 0.3 + \n                         (data.shareCount || 0) * 0.3);\n    return {\n      json: {\n        ...data,\n        qualityScore: qualityScore\n      }\n    };\n  });\n\nreturn filteredItems;"
      },
      "id": "filter-data",
      "name": "数据过滤分析",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [850, 300]
