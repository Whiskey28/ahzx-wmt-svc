<?xml version="1.0" encoding="UTF-8"?>
<definitions xmlns="http://www.omg.org/spec/BPMN/20100524/MODEL"
             xmlns:bpmndi="http://www.omg.org/spec/BPMN/20100524/DI"
             xmlns:dc="http://www.omg.org/spec/DD/20100524/DC"
             xmlns:di="http://www.omg.org/spec/DD/20100524/DI"
             xmlns:flowable="http://flowable.org/bpmn"
             targetNamespace="http://www.wmt.com/bpmn/ticket_lab_select">

  <process id="ticket_lab_select" name="工单实验-发起人自选" isExecutable="true">
    <documentation>启动时需传入 PROCESS_START_USER_SELECT_ASSIGNEES（由发起 API 写入）。用户任务 id 须为 Activity_select_approve，候选人策略 35（发起人自选）。</documentation>

    <startEvent id="start_sel" name="开始"/>

    <userTask id="Activity_select_approve" name="自选审批" flowable:candidateStrategy="35"/>

    <endEvent id="end_sel" name="结束"/>

    <sequenceFlow id="f1" sourceRef="start_sel" targetRef="Activity_select_approve"/>
    <sequenceFlow id="f2" sourceRef="Activity_select_approve" targetRef="end_sel"/>
  </process>

  <bpmndi:BPMNDiagram id="BPMNDiagram_ticket_lab_select">
    <bpmndi:BPMNPlane id="BPMNPlane_ticket_lab_select" bpmnElement="ticket_lab_select">
      <bpmndi:BPMNShape id="BPMNShape_start_sel" bpmnElement="start_sel">
        <dc:Bounds x="152" y="232" width="36" height="36"/>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="BPMNShape_Activity_select_approve" bpmnElement="Activity_select_approve">
        <dc:Bounds x="280" y="210" width="100" height="80"/>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="BPMNShape_end_sel" bpmnElement="end_sel">
        <dc:Bounds x="480" y="232" width="36" height="36"/>
      </bpmndi:BPMNShape>

      <bpmndi:BPMNEdge id="BPMNEdge_f1" bpmnElement="f1">
        <di:waypoint x="188" y="250"/>
        <di:waypoint x="280" y="250"/>
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="BPMNEdge_f2" bpmnElement="f2">
        <di:waypoint x="380" y="250"/>
        <di:waypoint x="480" y="250"/>
      </bpmndi:BPMNEdge>
    </bpmndi:BPMNPlane>
  </bpmndi:BPMNDiagram>
</definitions>
