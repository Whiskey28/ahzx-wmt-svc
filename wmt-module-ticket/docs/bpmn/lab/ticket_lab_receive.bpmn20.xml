<?xml version="1.0" encoding="UTF-8"?>
<definitions xmlns="http://www.omg.org/spec/BPMN/20100524/MODEL"
             xmlns:bpmndi="http://www.omg.org/spec/BPMN/20100524/DI"
             xmlns:dc="http://www.omg.org/spec/DD/20100524/DC"
             xmlns:di="http://www.omg.org/spec/DD/20100524/DI"
             xmlns:flowable="http://flowable.org/bpmn"
             targetNamespace="http://www.wmt.com/bpmn/ticket_lab_receive">

  <process id="ticket_lab_receive" name="工单实验-接收任务" isExecutable="true">
    <documentation>先完成「发起人提交」任务，再在业务详情页调用 /ticket/bpm-lab/trigger-receive 触发 Receive Task（Activity_receive_wait）。</documentation>

    <startEvent id="start_recv" name="开始"/>

    <userTask id="Activity_receive_before" name="发起人提交" flowable:candidateStrategy="36"/>

    <receiveTask id="Activity_receive_wait" name="等待外部回调"/>

    <endEvent id="end_recv" name="结束"/>

    <sequenceFlow id="r1" sourceRef="start_recv" targetRef="Activity_receive_before"/>
    <sequenceFlow id="r2" sourceRef="Activity_receive_before" targetRef="Activity_receive_wait"/>
    <sequenceFlow id="r3" sourceRef="Activity_receive_wait" targetRef="end_recv"/>
  </process>

  <bpmndi:BPMNDiagram id="BPMNDiagram_ticket_lab_receive">
    <bpmndi:BPMNPlane id="BPMNPlane_ticket_lab_receive" bpmnElement="ticket_lab_receive">
      <bpmndi:BPMNShape id="BPMNShape_start_recv" bpmnElement="start_recv">
        <dc:Bounds x="152" y="232" width="36" height="36"/>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="BPMNShape_Activity_receive_before" bpmnElement="Activity_receive_before">
        <dc:Bounds x="260" y="210" width="100" height="80"/>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="BPMNShape_Activity_receive_wait" bpmnElement="Activity_receive_wait">
        <dc:Bounds x="430" y="210" width="100" height="80"/>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="BPMNShape_end_recv" bpmnElement="end_recv">
        <dc:Bounds x="600" y="232" width="36" height="36"/>
      </bpmndi:BPMNShape>

      <bpmndi:BPMNEdge id="BPMNEdge_r1" bpmnElement="r1">
        <di:waypoint x="188" y="250"/>
        <di:waypoint x="260" y="250"/>
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="BPMNEdge_r2" bpmnElement="r2">
        <di:waypoint x="360" y="250"/>
        <di:waypoint x="430" y="250"/>
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="BPMNEdge_r3" bpmnElement="r3">
        <di:waypoint x="530" y="250"/>
        <di:waypoint x="600" y="250"/>
      </bpmndi:BPMNEdge>
    </bpmndi:BPMNPlane>
  </bpmndi:BPMNDiagram>
</definitions>
